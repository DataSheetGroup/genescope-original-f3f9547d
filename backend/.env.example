# Copy this file to backend/.env and fill in values
FLASK_ENV=development
FLASK_APP=app.py
PORT=5000

# Postgres connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genescope

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_HOURS=12
JWT_REMEMBER_EXPIRES_HOURS=720

# CORS: comma-separated list of allowed origins (frontend URLs)
CORS_ORIGINS=http://localhost:8080,https://your-custom-domain.com

# Path to your trained model pickle (optional)
MODEL_PATH=../public/models/my_trained_model.pkl
